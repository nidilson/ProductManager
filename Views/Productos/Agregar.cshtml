@using ProductManager.Models;
@model Producto
@{
    Layout = "../Shared/_Layout.cshtml";
    ViewBag.Title = "Agregar Producto";
}

<main>

    <div class="container mt-4">

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <div class="card shadow">

                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Agregar Producto</h3>
                    </div>

                    <div class="card-body">

                        @using (Html.BeginForm("Agregar", "Productos", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()

                            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                            <div class="mb-3">
                                @Html.LabelFor(m => m.SKU, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.SKU, new
                                {
                                    @class = "form-control",
                                    maxlength = "20",
                                    placeholder = "Ej. LAP-001"
                                })
                                @Html.ValidationMessageFor(m => m.SKU, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
                                @Html.TextBoxFor(m => m.Nombre, new
                                {
                                    @class = "form-control",
                                    maxlength = "50"
                                })
                                @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Categoria, new { @class = "form-label" })
                                @Html.EnumDropDownListFor(m => m.Categoria,
                                    "-- Seleccione una categoría --",
                                    new { @class = "form-select" })
                                @Html.ValidationMessageFor(m => m.Categoria, "", new { @class = "text-danger" })
                            </div>

                            <div class="mb-3">
                                @Html.LabelFor(m => m.Descripcion, new { @class = "form-label" })
                                @Html.TextAreaFor(m => m.Descripcion, 5, 0, new
                                {
                                    @class = "form-control",
                                    maxlength = "1000"
                                })
                                @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })
                            </div>

                            <div class="row">

                                <div class="col-md-6 mb-3">
                                    @Html.LabelFor(m => m.Precio, new { @class = "form-label" })
                                    @Html.TextBoxFor(m => m.Precio, new
                                    {
                                        @class = "form-control",
                                        type = "number",
                                        step = "0.01",
                                        min = "0"
                                    })
                                    @Html.ValidationMessageFor(m => m.Precio, "", new { @class = "text-danger" })
                                </div>

                                <div class="col-md-6 mb-3">
                                    @Html.LabelFor(m => m.Inventario, new { @class = "form-label" })
                                    @Html.TextBoxFor(m => m.Inventario, new
                                    {
                                        @class = "form-control",
                                        type = "number",
                                        min = "0"
                                    })
                                    @Html.ValidationMessageFor(m => m.Inventario, "", new { @class = "text-danger" })
                                </div>

                            </div>

                            <hr />

                            <div class="d-flex justify-content-between">

                                @Html.ActionLink("Volver", "Index", null,
                                    new { @class = "btn btn-secondary" })

                                <button type="submit" class="btn btn-success">
                                    Guardar Producto
                                </button>

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

    @section Scripts{
        @Scripts.Render("~/bundles/jqueryval")
    }

</main>
